{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "comment": "Vercel hosts the STATIC FRONTEND only. Backend goes on Render/Fly/Railway. After deploy, in the app's Settings tab set the API URL to your backend URL.",
  "buildCommand": "",
  "outputDirectory": "frontend",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    },
    {
      "source": "/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    }
  ]
}
